{
  "experiment_name": "paper-full",
  "paths": {
    "manifest": "data/caltech_large/manifest.json",
    "output_dir": "outputs/paper_caltech",
    "model_cache_dir": "models"
  },
  "runtime": {
    "device": "cuda",
    "seed": 42,
    "attack_limit": 50,
    "attack_offset": 0,
    "sequential_surrogates": false,
    "enable_tf32": true,
    "cudnn_benchmark": true
  },
  "attack": {
    "epsilon": 0.0627,
    "step_size": 0.004,
    "steps": 300,
    "image_size": 299,
    "augmentation_batches": 4,
    "augmentation_forward_batch_size": 4,
    "metrics_interval": 10,
    "temperature": 0.1,
    "top_k": 10,
    "relative_proxy_weight": 0.0,
    "patch_drop_rate": 0.2,
    "drop_path_max_rate": 0.15,
    "perturbation_ema_decay": 0.99,
    "gaussian_prob": 0.5,
    "gaussian_scale_multiplier": 0.25,
    "crop_prob": 0.5,
    "crop_scale_min": 0.8,
    "crop_scale_max": 1.0,
    "crop_ratio_min": 0.75,
    "crop_ratio_max": 1.3333333333,
    "pad_prob": 0.5,
    "jpeg_prob": 0.2,
    "jpeg_quality_min": 0.5,
    "jpeg_quality_max": 1.0,
    "jpeg_backend": "tensor",
    "enable_patch_drop": true,
    "enable_drop_path": true,
    "enable_perturbation_ema": true,
    "enable_gaussian": true,
    "enable_crop": true,
    "enable_pad": true,
    "enable_jpeg": true
  },
  "evaluation": {
    "success_margin_threshold": 0.0,
    "caption_victim": {
      "enabled": false,
      "model_name": "Salesforce/blip-image-captioning-base",
      "device": "cuda",
      "use_fp16": true,
      "sequential_loading": true,
      "max_new_tokens": 24,
      "num_beams": 3,
      "prompt": null,
      "require_source_absent": true
    },
    "vqa_victim": {
      "enabled": false,
      "model_name": "Salesforce/blip-vqa-base",
      "device": "cuda",
      "use_fp16": true,
      "sequential_loading": true,
      "max_new_tokens": 10,
      "num_beams": 3,
      "question_fallback": "What is the main object in the image?",
      "require_source_absent": true
    },
    "ocr_victim": {
      "enabled": false,
      "backend": "tesseract",
      "model_name": "microsoft/trocr-small-printed",
      "device": "cuda",
      "use_fp16": true,
      "sequential_loading": true,
      "max_new_tokens": 16,
      "num_beams": 1,
      "tesseract_psm": 7,
      "require_source_absent": true
    },
    "gpt_victim": {
      "enabled": false,
      "model_name": "gpt-4o",
      "task_type": "vqa",
      "api_mode": "auto",
      "prompt_mode": "freeform",
      "success_mode": "keyword",
      "question_fallback": "What is the main object in the image?",
      "caption_prompt": "Provide a concise description of the image using no more than three sentences.",
      "require_source_absent": true,
      "max_output_tokens": 64,
      "temperature": 0.0,
      "reasoning_effort": null,
      "api_key_env": "OPENAI_API_KEY",
      "base_url": "https://api.openai.com/v1",
      "request_user_agent": null,
      "request_timeout_seconds": 90,
      "max_retries": 4,
      "retry_backoff_seconds": 10.0,
      "request_pause_seconds": 0.0,
      "judge_model_name": "gpt-4o",
      "judge_api_mode": "auto",
      "judge_max_output_tokens": 128,
      "judge_temperature": 0.0,
      "judge_reasoning_effort": null,
      "judge_api_key_env": "OPENAI_API_KEY",
      "judge_base_url": "https://api.openai.com/v1"
    },
    "ollama_victim": {
      "enabled": false,
      "model_name": "qwen3-vl:4b",
      "base_url": "http://localhost:11434",
      "api_endpoint": "api/generate",
      "task_type": "vqa",
      "max_tokens": 128,
      "temperature": 0.0,
      "question_fallback": "What is the main object in the image?",
      "require_source_absent": true,
      "health_check_timeout": 5.0,
      "request_timeout": 60.0,
      "max_retries": 3,
      "retry_backoff": 2.0
    },
    "qwen_vl_victim": {
      "enabled": false,
      "model_name": "Qwen/Qwen2-VL-2B-Instruct",
      "device": "cuda",
      "use_fp16": true,
      "max_new_tokens": 64,
      "sequential_loading": true,
      "question_fallback": "What is the main object in the image?",
      "require_source_absent": true
    }
  },
